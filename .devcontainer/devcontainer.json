{
    "dockerFile": "dockerfile",
    "customizations": {
        "vscode": {
            "extensions": [
                "eamodio.gitlens",
                "GitHub.vscode-pull-request-github",
                "mhutchie.git-graph",
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ]
        }
    },
    "runArgs": [
        "--privileged"
    ],
    "remoteEnv": {
        "CCACHE_DIR" : "${containerWorkspaceFolder}/.ccache/",
        "CCACHE_MAXSIZE" : "15G"
    },
    "onCreateCommand": "git config --global --add safe.directory $PWD && pre-commit install"
}
